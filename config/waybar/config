{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 8,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["clock"],
   "modules-right": ["tray", "temperature", "cpu", "memory", "battery", "pulseaudio", "bluetooth", "network"],

    "network": {
        "format-wifi": "ΎΘτ  {essid}",
        "format-ethernet": "≤░ΙΑ Cableado",
        "format-disconnected": "έγι Sin Red",
        "tooltip-format": "Red Actual: {ifname}\nClic para buscar o cambiar red",
        "on-click": "alacritty -e nmtui" 
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚρ",
            "3": "ΎΕκ",
            "4": "ΎΘΑ",
            "urgent": "ΎΒς",
            "focused": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "sway/window": {
        "format": " {title} ",
        "max-length": 50
    },
    "clock": {
        "format": "≤▒ΣΤ {:%H:%M  ΎΒ│ %d %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "ΎΜΚ {temperatureC}┬░C",
        "format-critical": "ΎΜΘ {temperatureC}┬░C"
    },
    "cpu": {
        "format": "ΎΜδ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ΎΔΚ {}%"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "≤░ΨΒ Muted",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "ΎΛΦ {status}",
        "format-connected": "ΎΛΦ {device_alias}",
        "format-off": "ΎΛΦ Off",
        "on-click": "blueman-manager"
    },
    "network": {
        "format-wifi": "ΎΘτ  {essid}",
        "format-ethernet": "≤░ΙΑ  {ipaddr}",
        "format-disconnected": "έγι Sin Red",
        "tooltip-format": "{ifname} via {gwaddr}",
        "on-click": "alacritty -e nmtui" 
    },
    "tray": {
        "spacing": 10
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5"
    },
    "custom/power": {
        "format": "έΠ╗",
        "tooltip": false,
        "on-click": "wlogout -b 2"
    }
}
