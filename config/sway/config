# ==============================================================================
# 🚀 SWAY CONFIG - Edición Senior (QMK Dvorak + Home Row Mods)
# ==============================================================================

# --- 1. Variables Principales ---
set $mod Mod4
set $term alacritty
set $menu wofi --show drun

# --- 2. Monitores (Displays) ---
# Nota: Pendiente configurar posiciones usando `swaymsg -t get_outputs`.
output * bg ~/arch-setup/wallpaper.jpg fill

# --- 3. Atajos Globales del Sistema ---
bindsym $mod+Return exec $term
bindsym $mod+e exec $menu
bindsym $mod+Shift+L reload
bindsym $mod+Shift+Escape exec swaynag -t warning -m '¿Deseas salir de Sway?' -B 'Sí, salir' 'swaymsg exit'
bindsym Print exec flameshot gui

# 🚨 CORRECCIÓN: Cerrar ventana movido a "A" para no chocar con el Workspace 1
bindsym $mod+Shift+a kill

# Bloqueo de pantalla de seguridad (Swaylock con color Night Owl)
bindsym $mod+l exec swaylock -f -c 011627

# --- 4. Multimedia y Brillo ---
bindsym XF86AudioRaiseVolume exec pamixer -i 5
bindsym XF86AudioLowerVolume exec pamixer -d 5
bindsym XF86AudioMute exec pamixer -t
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym $mod+F12 exec rfkill toggle all

# --- 5. Navegación Física Dvorak (H, T, C, N) ---
# Foco
bindsym $mod+h focus left
bindsym $mod+t focus down
bindsym $mod+c focus up
bindsym $mod+n focus right

# Mover ventanas
bindsym $mod+Shift+h move left
bindsym $mod+Shift+t move down
bindsym $mod+Shift+c move up
bindsym $mod+Shift+n move right

# --- 6. Diseños (Layouts) ---
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+w layout tabbed
bindsym $mod+y layout toggle split
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle

# --- 7. Escritorios (Workspaces) adaptados para Corne Dvorak ---
# Ir a escritorio
bindsym $mod+q workspace number 1
bindsym $mod+j workspace number 2
bindsym $mod+k workspace number 3
bindsym $mod+x workspace number 4

# Mover ventana a escritorio
bindsym $mod+Shift+q move container to workspace number 1
bindsym $mod+Shift+j move container to workspace number 2
bindsym $mod+Shift+k move container to workspace number 3
bindsym $mod+Shift+x move container to workspace number 4

# Navegar entre escritorios activos
bindsym $mod+Tab workspace next_on_output
bindsym $mod+Shift+Tab workspace prev_on_output

# --- 8. Scratchpad (Ventanas ocultas temporales) ---
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# --- 9. Redimensionar Ventanas ---
mode "resize" {
    bindsym h resize shrink width 10px
    bindsym t resize grow height 10px
    bindsym c resize shrink height 10px
    bindsym n resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# --- 10. Hardware (Teclado y Touchpad) ---
input type:keyboard {
    xkb_layout us
    repeat_delay 300
    repeat_rate 50
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
}

# --- 11. Reglas de Ventanas (Window Rules) ---
for_window [app_id="blueman-manager"] floating enable, resize set width 600 height 400, move position center
for_window [app_id="pavucontrol"] floating enable, resize set width 600 height 400, move position center

# --- 12. Barra de Estado e Inicio Automático ---
bar {
    swaybar_command waybar
}

exec polkit-gnome-authentication-agent-1
exec blueman-applet

# --- 13. Estética y Gaps (Estilo Night Owl) ---
gaps inner 8
gaps outer 4
default_border pixel 2
default_floating_border pixel 2

# Colores de ventanas
client.focused          #82aaff   #011627    #d6deeb #addb67   #82aaff
client.unfocused        #1e3140   #011627    #575656 #1e3140   #1e3140
client.focused_inactive #1e3140   #011627    #d6deeb #1e3140   #1e3140
client.urgent           #ef5350   #011627    #ffffff #ef5350   #ef5350
