# ==============================================================================
# 🚀 SWAY CONFIG - Edición Senior (QMK Dvorak + Home Row Mods)
# ==============================================================================

# --- 1. Variables Principales ---
# Tu tecla Mod (Mod4) se activa manteniendo presionada la 'A' o la 'S'
set $mod Mod4

# Herramientas de élite
set $term alacritty
set $menu wofi --show drun

# --- 2. Monitores (Displays) ---
# Fondo oscuro base. Ajustar nombres (ej. DP-1, HDMI-A-1) tras ejecutar `swaymsg -t get_outputs`
output * bg #282a36 solid_color

# --- 3. Atajos Globales del Sistema ---
# Iniciar terminal (Mantén A + Enter)
bindsym $mod+Return exec $term

# Matar ventana actual (Mantén A + Shift + Q)
bindsym $mod+Shift+q kill

# Menú de aplicaciones Wofi (Mantén A + D... nota: D en Dvorak es 'e' física, ajusta si prefieres otra)
bindsym $mod+e exec $menu

# Recargar configuración de Sway (Mantén A + Shift + C)
bindsym $mod+Shift+c reload

# Salir de Sway
bindsym $mod+Shift+Escape exec swaynag -t warning -m '¿Deseas salir de Sway?' -B 'Sí, salir' 'swaymsg exit'

# --- 4. Navegación Física Dvorak (D, H, T, N) ---
# Mover el foco entre ventanas sin mover la mano derecha de la fila central
bindsym $mod+d focus left   # Dedo índice
bindsym $mod+h focus down   # Dedo medio
bindsym $mod+t focus up     # Dedo anular
bindsym $mod+n focus right  # Dedo meñique

# Mover la ventana en sí (Añadiendo Shift)
bindsym $mod+Shift+d move left
bindsym $mod+Shift+h move down
bindsym $mod+Shift+t move up
bindsym $mod+Shift+n move right

# --- 5. Diseños (Layouts) ---
# Dividir en horizontal y vertical (Usamos B y V que están en tu mano derecha abajo)
bindsym $mod+b splith
bindsym $mod+v splitv

# Estilos de ventana
bindsym $mod+w layout tabbed         # Agrupar en pestañas
bindsym $mod+y layout toggle split   # Volver a mosaico
bindsym $mod+f fullscreen            # Pantalla completa
bindsym $mod+Shift+space floating toggle # Hacer ventana flotante

# --- 6. Escritorios (Workspaces) ---
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# --- 7. Redimensionar Ventanas (Modo especial) ---
mode "resize" {
    # Usamos las mismas teclas de navegación D, H, T, N
    bindsym d resize shrink width 10px
    bindsym h resize grow height 10px
    bindsym t resize shrink height 10px
    bindsym n resize grow width 10px

    # Salir del modo resize
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
# Entrar en modo redimensión (Mantén A + R)
bindsym $mod+r mode "resize"

# --- 8. Barra de Estado (Waybar) ---
bar {
    swaybar_command waybar
}

# --- 9. Inicio Automático ---
exec polkit-gnome-authentication-agent-1
# exec mako (Descomentar para habilitar notificaciones)
